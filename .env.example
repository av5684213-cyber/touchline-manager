# Touchline Manager — Environment Variables
# Bu dosyayı kendi .env dosyanızı oluşturmak için şablon olarak kullanın.
# Gerçek değerleri .env dosyasına yazın (.env gitignore'da, commit edilmez).

# Supabase — public (client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role (sadece server-side, ASLA client'a expose etme)
SUPABASE_SERVICE_ROLE_KEY=

# Cron job'lar için shared secret (Vercel cron header'ı doğrulamak için)
CRON_SECRET=

# Auth (varsa)
NEXTAUTH_SECRET=
