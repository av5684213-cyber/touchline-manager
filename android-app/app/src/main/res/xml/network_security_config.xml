<?xml version="1.0" encoding="utf-8"?>
<!--
  ════════════════════════════════════════════════════════════════════════════
  NETWORK SECURITY CONFIG — v2.9.13
  ════════════════════════════════════════════════════════════════════════════
  Tüm trafik HTTPS zorunlu. Cleartext (HTTP) tamamen yasak.

  - Varsayılan: cleartextTrafficPermitted = false (tüm domain'ler)
  - Supabase domain'i: HTTPS only (pinning yok ama HTTPS zorunlu)
  - Mixed content: native seviyede MIXED_CONTENT_NEVER_ALLOW ile engelli

  Bu config AndroidManifest'te android:networkSecurityConfig ile bağlı.
  file:// URL'leri (WebView assets) etkilenmez — sadece network trafiği.
  ════════════════════════════════════════════════════════════════════════════
-->
<network-security-config>
    <!-- Varsayılan: tüm domain'ler için cleartext yasak -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Supabase domain'i — HTTPS zorunlu, certificate pinning yok -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- localhost (geliştirme amaçlı, production'da etkisiz) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
